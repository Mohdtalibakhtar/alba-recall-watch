# AlbaCars Recall & Safety Watch — credential reference
# These live in n8n's credential store, NOT in the workflow JSON. Never commit real values.

# 1. Anthropic API key — stored as an n8n "Header Auth" credential
#    Header name:  x-api-key
#    Header value: <your key>
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. Slack Incoming Webhook — pasted into the "Slack — post" node URL field
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR-WEBHOOK

# NHTSA vPIC + Recalls APIs require NO key (public, keyless).
